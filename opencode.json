{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "cloudflare": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:CLOUDFLARE_API_TOKEN}"
      }
    },
    "coolify": {
      "type": "local",
      "command": ["npx", "-y", "@masonator/coolify-mcp"],
      "enabled": true,
      "env": {
        "COOLIFY_ACCESS_TOKEN": "{env:COOLIFY_ACCESS_TOKEN}",
        "COOLIFY_BASE_URL": "{env:COOLIFY_BASE_URL}"
      }
    },
    "contabo": {
      "type": "local",
      "command": ["npx", "-y", "@kieksme/contabo-mcp"],
      "enabled": true,
      "env": {
        "CONTABO_CLIENT_ID": "{env:CONTABO_CLIENT_ID}",
        "CONTABO_CLIENT_SECRET": "{env:CONTABO_CLIENT_SECRET}",
        "CONTABO_API_USER": "{env:CONTABO_API_USER}",
        "CONTABO_API_PASSWORD": "{env:CONTABO_API_PASSWORD}"
      }
    }
  }
}
