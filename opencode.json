{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "cloudflare": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:CLOUDFLARE_API_TOKEN}"
      }
    },
    "coolify": {
      "type": "local",
      "command": ["npx", "-y", "@masonator/coolify-mcp"],
      "enabled": true,
      "env": {
        "COOLIFY_ACCESS_TOKEN": "{env:COOLIFY_ACCESS_TOKEN}",
        "COOLIFY_BASE_URL": "{env:COOLIFY_BASE_URL}"
      }
    },
    "grafana": {
      "type": "local",
      "command": ["npx", "-y", "@leval/mcp-grafana"],
      "enabled": true,
      "env": {
        "GRAFANA_URL": "{env:GRAFANA_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      }
    }
  }
}
